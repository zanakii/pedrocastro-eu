---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
  href?: string;
  meta?: string;
  image?: string;
}
const { label, title, subtitle, href, meta, image } = Astro.props;
---

<article class="now">
  {image && (
    <img
      class="thumb"
      src={image}
      alt={`${label}: ${title}`}
      loading="lazy"
      decoding="async"
      referrerpolicy="no-referrer"
    />
  )}
  <div class="body">
    <span class="label">{label}</span>
    {href ? (
      <a class="title" href={href} rel="noopener">{title}</a>
    ) : (
      <span class="title">{title}</span>
    )}
    {subtitle && <div class="subtitle muted">{subtitle}</div>}
    {meta && <div class="meta small">{meta}</div>}
  </div>
</article>

<style>
  .now {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--surface);
    transition:
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }
  .now:hover {
    border-color: var(--accent-ring);
    background: var(--surface-hover);
    transform: translateY(-1px);
  }
  .thumb {
    height: 3.75rem;
    width: 3.75rem;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 2px 10px rgb(0 0 0 / 0.35);
    outline: 1px solid var(--rule-strong);
    outline-offset: -1px;
    flex: none;
  }
  .body { min-width: 0; }
  .label {
    display: block;
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }
  .title {
    font-family: var(--font-serif);
    font-size: 1.12rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  a.title { text-decoration: none; }
  a.title:hover { color: var(--accent-bright); }
  .subtitle {
    margin-top: 0.1rem;
    font-size: 0.92rem;
  }
  .meta {
    margin-top: 0.2rem;
    color: var(--muted);
  }
</style>
