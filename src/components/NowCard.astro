---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
  href?: string;
  meta?: string;
  image?: string;
}
const { label, title, subtitle, href, meta, image } = Astro.props;
---

<div class="now">
  <span class="label">{label}</span>
  <div class="row">
    {image && (
      <img
        class="thumb"
        src={image}
        alt={`${label}: ${title}`}
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
      />
    )}
    <div class="body">
      {href ? (
        <a href={href} rel="noopener">{title}</a>
      ) : (
        <span class="title">{title}</span>
      )}
      {subtitle && <div class="subtitle muted">{subtitle}</div>}
      {meta && <div class="meta muted small">{meta}</div>}
    </div>
  </div>
</div>

<style>
  .now {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.6rem 0;
  }
  .label {
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .thumb {
    height: 3.5rem;
    width: auto;
    max-width: 3.5rem;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.18);
    flex: none;
  }
  .body { min-width: 0; }
  .title { font-weight: 500; }
  .subtitle { font-style: italic; }
  .meta { margin-top: 0.15rem; }
  @media (max-width: 30rem) {
    .now { grid-template-columns: 1fr; gap: 0.15rem; }
  }
</style>
