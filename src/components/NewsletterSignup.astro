---
const archiveUrl = 'https://newsletter.pedrocastro.eu';
---

<div class="signup">
  <div class="form-slot">
    <script
      is:inline
      async
      src="https://subscribe-forms.beehiiv.com/v3/loader.js"
      data-beehiiv-form="196a3230-ed52-41ca-928a-9dffced2b000"
    ></script>
  </div>
  <p class="small muted archive">
    Read the archive at <a href={archiveUrl}>{archiveUrl.replace(/^https?:\/\//, '')}</a>.
  </p>
</div>

<style>
  .signup {
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 1.1rem 1.35rem;
    background: var(--surface);
  }
  .form-slot { min-height: 3rem; }
  .archive { margin-top: 0.75rem; margin-bottom: 0; }
</style>
