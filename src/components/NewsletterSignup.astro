---
const beehiivPublicationId = import.meta.env.PUBLIC_BEEHIIV_PUBLICATION_ID;
const beehiivUrl = import.meta.env.PUBLIC_BEEHIIV_URL ?? 'https://newsletter.pedrocastro.eu';
---

<div class="signup">
  {beehiivPublicationId ? (
    <iframe
      src={`https://embeds.beehiiv.com/${beehiivPublicationId}?slim=true`}
      data-test-id="beehiiv-embed"
      height="52"
      frameborder="0"
      scrolling="no"
      style="margin: 0; border-radius: 0; background-color: transparent;"
      title="Subscribe to the newsletter"
    ></iframe>
  ) : (
    <p class="muted small">
      Newsletter embed not configured yet. Set <code>PUBLIC_BEEHIIV_PUBLICATION_ID</code>{' '}
      to enable the inline form, or just link out below.
    </p>
  )}
  <p class="small muted">
    Read the archive at <a href={beehiivUrl}>{beehiivUrl.replace(/^https?:\/\//, '')}</a>.
  </p>
</div>

<style>
  .signup {
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--bg) 80%, var(--fg) 4%);
  }
  iframe { width: 100%; display: block; }
  code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 0.85em;
    padding: 0.05em 0.3em;
    background: var(--rule);
    border-radius: 3px;
  }
</style>
