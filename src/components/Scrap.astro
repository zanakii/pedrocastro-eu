---
import { render, type CollectionEntry } from 'astro:content';
import { formatScrapDate } from '../lib/scraps';

interface Props {
  entry: CollectionEntry<'scraps'>;
}
const { entry } = Astro.props;
// Render the short Markdown body inline; inline links inherit the global anchor
// styling (accent on hover), which is the family tie back to the Now cards.
const { Content } = await render(entry);
---

<article class="scrap" id={entry.id}>
  <div class="scrap-body">
    <Content />
  </div>
  <time class="scrap-date" datetime={entry.data.date.toISOString()}>
    {formatScrapDate(entry.data.date)}
  </time>
</article>

<style>
  /* Scraps are prose-led (body font, not Now's serif) and hang off a left
     timeline rule drawn by the parent `.scrap-thread`. The dot sits on that
     rule; --thread-pad is inherited from the wrapper so they stay aligned. */
  .scrap-body {
    color: var(--fg-dim);
    font-family: var(--font-serif-text);
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.55;
  }
  .scrap-body :global(p) {
    margin: 0 0 0.6rem;
  }
  .scrap-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .scrap-date {
    position: relative;
    display: block;
    margin-top: 0.55rem;
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  /* The node sits on the parent's left rule, vertically centred on the date. */
  .scrap-date::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--thread-pad, 1.35rem) - 3px);
    top: 50%;
    transform: translateY(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    /* Mask the rule behind the dot so it reads as a clean node on the line. */
    box-shadow: 0 0 0 4px var(--bg);
  }
</style>
