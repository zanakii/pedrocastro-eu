---
import Layout from '../layouts/Layout.astro';
import NowCard from '../components/NowCard.astro';
import { getNow, formatRelative, formatStars } from '../lib/now';

const now = getNow();

const listeningTitle = now.listening.track ?? '—';
const listeningSubtitle = [now.listening.artist, now.listening.album]
  .filter(Boolean)
  .join(' · ');
const listeningMeta = now.listening.nowPlaying
  ? 'now playing'
  : formatRelative(now.listening.playedAt) ?? null;

const readingTitle = now.reading.title ?? '—';
const readingSubtitle = now.reading.author ?? undefined;
const readingMeta = formatRelative(now.reading.startedAt) ?? null;

const watchingTitle = now.watching.title
  ? now.watching.year
    ? `${now.watching.title} (${now.watching.year})`
    : now.watching.title
  : '—';
const watchingStars = formatStars(now.watching.rating);
const watchingSubtitle = [watchingStars, now.watching.rewatch ? 'rewatch' : null]
  .filter(Boolean)
  .join(' · ');
const watchingRelative = formatRelative(now.watching.watchedAt);
const watchingMeta = watchingRelative ? `watched ${watchingRelative}` : null;

const lastUpdated = formatRelative(now.updatedAt);
---

<Layout
  title="Pedro Castro"
  description="Pedro Castro — personal site, newsletter, and what I'm reading and listening to."
>
  <header>
    <h1>Pedro Castro</h1>
    <p class="muted bio">
      Based in Lisbon, Portugal. I work in AI and Higher Education, and in my pastime try to read, write, and chill.
    </p>
    <ul class="links" aria-label="Links">
      <li>
        <a href="mailto:hello@pedrocastro.eu" aria-label="Email" title="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/zanakii" aria-label="GitHub" title="GitHub" rel="me">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/pmcastro/" aria-label="LinkedIn" title="LinkedIn" rel="me">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect width="4" height="12" x="2" y="9" />
            <circle cx="4" cy="4" r="2" />
          </svg>
        </a>
      </li>
    </ul>
  </header>

  <section>
    <h2>Now</h2>
    <div class="now-list">
    <NowCard
      label="Reading"
      title={readingTitle}
      subtitle={readingSubtitle}
      href={now.reading.url ?? undefined}
      meta={readingMeta ? `started ${readingMeta}` : undefined}
      image={now.reading.cover ?? undefined}
    />
    <NowCard
      label="Watching"
      title={watchingTitle}
      subtitle={watchingSubtitle || undefined}
      href={now.watching.url ?? undefined}
      meta={watchingMeta ?? undefined}
      image={now.watching.poster ?? undefined}
    />
    <NowCard
      label="Listening"
      title={listeningTitle}
      subtitle={listeningSubtitle || undefined}
      href={now.listening.url ?? undefined}
      meta={listeningMeta ?? undefined}
      image={now.listening.image ?? undefined}
    />
    </div>
    <p class="before">
      <a href="/media/">Before →</a>
    </p>
  </section>

  <footer>
    <p>
      © {new Date().getFullYear()} Pedro Castro ·
      {lastUpdated ? ` Now updated ${lastUpdated}` : ' Now data not yet populated'}
    </p>
  </footer>
</Layout>

<style>
  header { margin-bottom: 1.5rem; }
  .bio {
    margin-bottom: 1.25rem;
    max-width: 32rem;
  }
  .now-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .before {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--rule);
    border-radius: 9px;
    background: var(--surface);
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background 140ms ease,
      transform 140ms ease;
  }
  .links a:hover,
  .links a:focus-visible {
    color: var(--accent-bright);
    border-color: var(--accent-ring);
    background: var(--surface-hover);
    transform: translateY(-1px);
    outline: none;
  }
  .links svg {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }
</style>
