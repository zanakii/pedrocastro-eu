---
import Layout from '../layouts/Layout.astro';
import NowCard from '../components/NowCard.astro';
import Scrap from '../components/Scrap.astro';
import { getCollection } from 'astro:content';
import { getNow, formatRelative, formatStars } from '../lib/now';
import { getSortedScraps } from '../lib/scraps';

const now = getNow();

// The three most recent scraps, as a homepage window into /scraps/.
const scraps = (await getSortedScraps()).slice(0, 3);

// The five most recent flashes, as a homepage preview into /flashes/.
const flashes = (
  await getCollection('flashes', (f) =>
    import.meta.env.PROD ? !f.data.draft : true,
  )
)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

// Each Now card carries a `sortAt` (ms) so the section reads chronologically —
// the most recent activity of each kind, ordered newest-first regardless of
// which medium it is. A now-playing track counts as happening right now.
const ms = (iso: string | null): number => {
  if (!iso) return 0;
  const t = new Date(iso).getTime();
  return Number.isNaN(t) ? 0 : t;
};

const withYear = (title: string | null, year: string | number | null) =>
  title ? (year ? `${title} (${year})` : title) : '—';

const seriesEp =
  now.series.season && now.series.number
    ? `S${now.series.season}E${now.series.number}`
    : null;

const cards = [
  {
    label: 'Reading',
    title: now.reading.title ?? '—',
    subtitle: now.reading.author ?? undefined,
    href: now.reading.url ?? undefined,
    meta: formatRelative(now.reading.startedAt)
      ? `started ${formatRelative(now.reading.startedAt)}`
      : undefined,
    image: now.reading.cover ?? undefined,
    present: Boolean(now.reading.title),
    sortAt: ms(now.reading.startedAt),
  },
  {
    label: 'Binging',
    title: withYear(now.series.show, now.series.year),
    subtitle: [seriesEp, now.series.episode].filter(Boolean).join(' · ') || undefined,
    href: now.series.url ?? undefined,
    meta: formatRelative(now.series.watchedAt)
      ? `watched ${formatRelative(now.series.watchedAt)}`
      : undefined,
    image: now.series.image ?? undefined,
    present: Boolean(now.series.show),
    sortAt: ms(now.series.watchedAt),
  },
  {
    label: 'Seen',
    title: withYear(now.watching.title, now.watching.year),
    subtitle:
      [formatStars(now.watching.rating), now.watching.rewatch ? 'rewatch' : null]
        .filter(Boolean)
        .join(' · ') || undefined,
    href: now.watching.url ?? undefined,
    meta: formatRelative(now.watching.watchedAt)
      ? `watched ${formatRelative(now.watching.watchedAt)}`
      : undefined,
    image: now.watching.poster ?? undefined,
    present: Boolean(now.watching.title),
    sortAt: ms(now.watching.watchedAt),
  },
  {
    label: 'Listening',
    title: now.listening.track ?? '—',
    subtitle:
      [now.listening.artist, now.listening.album].filter(Boolean).join(' · ') || undefined,
    href: now.listening.url ?? undefined,
    meta: now.listening.nowPlaying
      ? 'now playing'
      : formatRelative(now.listening.playedAt) ?? undefined,
    image: now.listening.image ?? undefined,
    present: Boolean(now.listening.track),
    // A now-playing track is happening right now, so it sorts to the top.
    sortAt: now.listening.nowPlaying ? Date.now() : ms(now.listening.playedAt),
  },
]
  .filter((c) => c.present)
  .sort((a, b) => b.sortAt - a.sortAt);

const lastUpdated = formatRelative(now.updatedAt);
---

<Layout
  title="Pedro Castro"
  description="Pedro Castro — personal site, newsletter, and what I'm reading and listening to."
>
  <header>
    <h1>Pedro Castro</h1>
    <p class="muted bio">
      Based in Lisbon, Portugal. I work in AI and Higher Education, and in my pastime try to read, write, and chill.
    </p>
    <ul class="links" aria-label="Links">
      <li>
        <a href="mailto:hello@pedrocastro.eu" aria-label="Email" title="Email">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </a>
      </li>
      <li>
        <a href="/rss.xml" aria-label="RSS feed" title="RSS feed" type="application/rss+xml">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/zanakii" aria-label="GitHub" title="GitHub" rel="me">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/pmcastro/" aria-label="LinkedIn" title="LinkedIn" rel="me">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect width="4" height="12" x="2" y="9" />
            <circle cx="4" cy="4" r="2" />
          </svg>
        </a>
      </li>
    </ul>
  </header>

  <section>
    <h2>Now</h2>
    <div class="now-list">
    {cards.map((c) => (
      <NowCard
        label={c.label}
        title={c.title}
        subtitle={c.subtitle}
        href={c.href}
        meta={c.meta}
        image={c.image}
      />
    ))}
    </div>
    <p class="before">
      <a href="/before/">Before →</a>
    </p>
  </section>

  {scraps.length > 0 && (
    <section>
      <h2>Scraps</h2>
      <div class="scrap-thread">
        {scraps.map((s) => <Scrap entry={s} />)}
      </div>
      <p class="before">
        <a href="/scraps/">More scraps →</a>
      </p>
    </section>
  )}

  {flashes.length > 0 && (
    <section>
      <h2>Flashes</h2>
      <div class="flash-strip">
        {flashes.map((f) => (
          <a class="flash-thumb" href="/flashes/" aria-label={f.data.alt || f.data.caption || 'Flash'}>
            <img src={f.data.image} alt={f.data.alt} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
      <p class="before">
        <a href="/flashes/">More →</a>
      </p>
    </section>
  )}

  <footer>
    <p>
      © {new Date().getFullYear()} Pedro Castro ·
      {lastUpdated ? `Now updated ${lastUpdated} · ` : 'Now data not yet populated · '}
      <a href="/now/">Now</a> ·
      <a href="/uses/">Uses</a> ·
      <a href="/colophon/">Colophon</a>
    </p>
  </footer>
</Layout>

<style>
  header { margin-bottom: 1.5rem; }
  .bio {
    margin-bottom: 1.25rem;
    max-width: 32rem;
  }
  .now-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .before {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .scrap-thread {
    --thread-pad: 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 1.9rem;
    border-left: 1px solid var(--rule);
    padding-left: var(--thread-pad);
  }
  .flash-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
  }
  .flash-thumb {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--rule);
    background: var(--surface);
    transition: border-color 140ms ease, transform 140ms ease;
  }
  .flash-thumb:hover {
    border-color: var(--accent-ring);
    transform: translateY(-1px);
  }
  .flash-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 30rem) {
    .flash-strip { grid-template-columns: repeat(3, 1fr); }
  }

  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--rule);
    border-radius: 9px;
    background: var(--surface);
    transition:
      color 140ms ease,
      border-color 140ms ease,
      background 140ms ease,
      transform 140ms ease;
  }
  .links a:hover,
  .links a:focus-visible {
    color: var(--accent-bright);
    border-color: var(--accent-ring);
    background: var(--surface-hover);
    transform: translateY(-1px);
    outline: none;
  }
  .links svg {
    width: 1.1rem;
    height: 1.1rem;
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }
</style>
