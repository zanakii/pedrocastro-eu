---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pedro Castro',
  description = 'Personal site of Pedro Castro.',
} = Astro.props;

const path = Astro.url.pathname;
const nav = [
  { label: 'Home', href: '/', active: path === '/' },
  { label: 'Posts', href: '/posts/', active: path.startsWith('/posts/') },
  { label: 'Flashes', href: '/flashes/', active: path.startsWith('/flashes/') },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Resolve theme before paint to avoid a flash of the wrong palette.
      (() => {
        const stored = localStorage.getItem('theme');
        const theme = stored === 'light' || stored === 'dark'
          ? stored
          : matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="Pedro Castro" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        {nav.map((item) => (
          <a href={item.href} aria-current={item.active ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
        <button
          type="button"
          class="theme-toggle"
          aria-label="Toggle color theme"
          title="Toggle color theme"
        >
          <svg class="icon-sun" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
          </svg>
        </button>
      </nav>
    </header>
    <script>
      const btn = document.querySelector('.theme-toggle');
      btn?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
    <main>
      <slot />
    </main>
    <style is:global>
      :root {
        /* Dark, green-tinted premium palette (default) */
        --bg: #0d0f0e;
        --surface: #141816;
        --surface-hover: #181d1a;
        --fg: #ededed;
        --fg-dim: #c6c9c6;
        --muted: #868d88;
        --accent: #4db389;
        --accent-bright: #62cf9f;
        --accent-soft: rgba(77, 179, 137, 0.1);
        --accent-ring: rgba(77, 179, 137, 0.32);
        --rule: #232826;
        --rule-strong: #2d3531;
        --header-bg: rgba(13, 15, 14, 0.74);
        --tint: rgba(77, 179, 137, 0.07);
        --thumb-shadow: 0 2px 10px rgb(0 0 0 / 0.35);
        --max-w: 40rem;
        --font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
        --font-serif: 'Fraunces', ui-serif, Georgia, 'Iowan Old Style', serif;
      }
      :root[data-theme='light'] {
        /* Light, green-tinted warm-paper palette */
        --bg: #f7f8f6;
        --surface: #ffffff;
        --surface-hover: #eef2ee;
        --fg: #16201b;
        --fg-dim: #3c443f;
        --muted: #687069;
        --accent: #2f9068;
        --accent-bright: #237a56;
        --accent-soft: rgba(47, 144, 104, 0.1);
        --accent-ring: rgba(47, 144, 104, 0.35);
        --rule: #e3e7e3;
        --rule-strong: #d1d7d2;
        --header-bg: rgba(247, 248, 246, 0.78);
        --tint: rgba(47, 144, 104, 0.06);
        --thumb-shadow: 0 2px 10px rgb(20 32 27 / 0.12);
      }
      * { box-sizing: border-box; }
      html { font-size: 17px; -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        background: var(--bg);
        background-image:
          radial-gradient(55rem 26rem at 50% -12rem, var(--tint), transparent 70%);
        background-repeat: no-repeat;
        background-attachment: fixed;
        color: var(--fg);
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        /* --bg at ~74-78% so the green-tint radial behind shows through the blur */
        background: var(--header-bg);
        backdrop-filter: blur(12px) saturate(135%);
        -webkit-backdrop-filter: blur(12px) saturate(135%);
        border-bottom: 1px solid var(--rule);
      }
      .site-nav {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0.55rem 1.5rem;
        display: flex;
        gap: 1.4rem;
        font-size: 0.82rem;
        letter-spacing: 0.01em;
      }
      .site-nav a {
        color: var(--muted);
        text-decoration: none;
        padding: 0.15rem 0;
        border-bottom: 1px solid transparent;
        transition: color 140ms ease, border-color 140ms ease;
      }
      .site-nav a:hover {
        color: var(--fg);
      }
      .site-nav a[aria-current='page'] {
        color: var(--fg);
        border-bottom-color: var(--accent);
      }
      .theme-toggle {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.25rem;
        color: var(--muted);
        background: transparent;
        border: 0;
        cursor: pointer;
        border-radius: 6px;
        transition: color 140ms ease, background 140ms ease;
      }
      .theme-toggle:hover {
        color: var(--fg);
        background: var(--surface-hover);
      }
      .theme-toggle:focus-visible {
        outline: 2px solid var(--accent-ring);
        outline-offset: 2px;
      }
      /* Moon while dark, sun while light — the icon reflects the current theme. */
      .theme-toggle .icon-sun { display: none; }
      :root[data-theme='light'] .theme-toggle .icon-moon { display: none; }
      :root[data-theme='light'] .theme-toggle .icon-sun { display: inline; }
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 2.5rem 1.5rem 6rem;
      }
      h1, h2, h3 { font-weight: 500; letter-spacing: -0.015em; }
      h1 {
        font-family: var(--font-serif);
        font-size: 2.3rem;
        font-weight: 500;
        line-height: 1.1;
        margin: 0 0 0.65rem;
      }
      h2 {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        font-family: var(--font-sans);
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--muted);
        margin: 3rem 0 1rem;
      }
      h2::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, var(--rule), transparent);
      }
      p { margin: 0 0 0.9rem; color: var(--fg-dim); }
      a {
        color: var(--fg);
        text-decoration: underline;
        text-decoration-color: var(--rule-strong);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 140ms ease, text-decoration-color 140ms ease;
      }
      a:hover {
        text-decoration-color: var(--accent);
        color: var(--accent-bright);
      }
      hr {
        border: 0;
        border-top: 1px solid var(--rule);
        margin: 2rem 0;
      }
      .muted { color: var(--muted); }
      .small { font-size: 0.85rem; }
      ::selection {
        background: var(--accent-soft);
        color: var(--accent-bright);
      }
      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
        font-size: 0.8rem;
        color: var(--muted);
        font-family: var(--font-sans);
      }
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
